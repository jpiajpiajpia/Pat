{
  "name": "pat",
  "version": "1.3.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "ts-node --esm prisma/seed.ts",
    "db:studio": "prisma studio",
    "electron:dev": "electron .",
    "electron:build": "next build --webpack && electron-builder --mac --arm64",
    "dist": "npm run electron:build"
  },
  "prisma": {
    "seed": "npx ts-node --esm prisma/seed.ts"
  },
  "build": {
    "appId": "com.pat.local",
    "productName": "Pat",
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "prisma/**/*",
      "node_modules/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/.bin/**/*",
      "package.json",
      "next.config.ts",
      "next-env.d.ts"
    ],
    "extraResources": [
      {
        "from": "data/",
        "to": "app/data/"
      },
      {
        "from": "node_modules/.prisma",
        "to": "app.asar.unpacked/node_modules/.prisma"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Install Pat",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 180,
          "type": "file"
        },
        {
          "x": 400,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "directories": {
      "buildResources": "electron/icons",
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/.bin/**/*",
      ".next/**/*",
      "prisma/**/*",
      "public/**/*",
      "next.config.ts",
      "next-env.d.ts",
      "package.json"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.66",
    "@ai-sdk/react": "^3.0.176",
    "@base-ui/react": "^1.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/canvas": "^0.1.100",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "ai": "^3.4.33",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "glob": "^13.0.6",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "next": "16.2.4",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.6.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.19.39",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
